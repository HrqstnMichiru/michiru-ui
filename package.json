{
    "name": "michiru-ui",
    "version": "1.0.0",
    "description": "A Vue 3 UI Component Library",
    "author": "Hrqstn Michiru",
    "license": "MIT",
    "keywords": [
        "vue",
        "vue3",
        "ui",
        "components",
        "component-library",
        "michiru-ui"
    ],
    "files": [
        "dist"
    ],
    "main": "./dist/michiru-ui.umd.js",
    "module": "./dist/michiru-ui.es.js",
    "types": "./dist/index.d.ts",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/michiru-ui.es.js",
            "require": "./dist/michiru-ui.umd.js"
        },
        "./style.css": "./dist/michiru-ui.css"
    },
    "engines": {
        "node": "^20.19.0 || >=22.12.0"
    },
    "scripts": {
        "dev": "vite",
        "build": "run-p type-check build-only",
        "build-only": "vite build && vue-tsc --build",
        "clean": "rm -rf dist",
        "preview": "vite preview",
        "type-check": "vue-tsc --build --noEmit",
        "lint": "eslint . --fix --cache",
        "format": "prettier --write --experimental-cli src/",
        "generate": "tsx example/scripts/generate.ts"
    },
    "dependencies": {
        "@iconify/vue": "^5.0.0",
        "dayjs": "^1.11.19",
        "lodash-es": "^4.17.22",
        "nanoid": "^5.1.6",
        "smooth-scrollbar": "^8.8.4"
    },
    "peerDependencies": {
        "vue": ">=3.5.0",
        "vue-router": ">=4.2.0"
    },
    "devDependencies": {
        "@tsconfig/node24": "^24.0.3",
        "@types/lodash-es": "^4.17.12",
        "@types/node": "^24.10.1",
        "@vitejs/plugin-vue": "^6.0.2",
        "@vue/eslint-config-prettier": "^10.2.0",
        "@vue/eslint-config-typescript": "^14.6.0",
        "@vue/tsconfig": "^0.8.1",
        "eslint": "^9.39.1",
        "eslint-plugin-vue": "~10.5.1",
        "image-size": "^2.0.2",
        "jiti": "^2.6.1",
        "npm-run-all2": "^8.0.4",
        "prettier": "3.6.2",
        "sass": "^1.97.1",
        "sass-loader": "^16.0.6",
        "tsx": "^4.21.0",
        "typescript": "~5.9.0",
        "vite": "^7.2.4",
        "vite-plugin-vue-devtools": "^8.0.5",
        "vue-tsc": "^3.1.5"
    }
}
